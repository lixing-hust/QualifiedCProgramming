debug < 1 goal
  
  target_pre, a_pre, n_pre : Z
  l : list Z
  left, mid, right : Z
  H : Znth mid l 0 >= target_pre
  H0 : left <= mid
  H1 : mid <= right
  H2 : 0 <= mid
  H3 : mid < n_pre
  H4 : Zlength l = n_pre
  H5 :
    forall i_3 : Z,
    0 <= i_3 /\ i_3 + 1 < n_pre -> Znth i_3 l 0 <= Znth (i_3 + 1) l 0
  H6 : forall j_3 : Z, 0 <= j_3 < left -> Znth j_3 l 0 < target_pre
  H7 : forall j_4 : Z, right < j_4 < n_pre -> target_pre < Znth j_4 l 0
  ============================
  IntArray.full a_pre n_pre l ** &( "mid") # Int |-> mid
  |-- [|0 <= left|] &&
      ([|left <= n_pre|] &&
       ([|-1 <= mid - 1|] &&
        ([|mid - 1 < n_pre|] &&
         ([|left <= mid - 1 + 1|] &&
          ([|Zlength l = n_pre|] &&
           ([|forall i_3 : Z,
              0 <= i_3 /\ i_3 + 1 < n_pre ->
              Znth i_3 l 0 <= Znth (i_3 + 1) l 0|] &&
            ([|forall j_3 : Z, 0 <= j_3 < left -> Znth j_3 l 0 < target_pre|] &&
             ([|forall j_2 : Z,
                mid - 1 < j_2 < n_pre -> target_pre < Znth j_2 l 0|] &&
              ([|0 <= n_pre|] &&
               ([|Zlength l = n_pre|] &&
                ([|forall i_3 : Z,
                   0 <= i_3 /\ i_3 + 1 < n_pre ->
                   Znth i_3 l 0 <= Znth (i_3 + 1) l 0|] &&
                 IntArray.full a_pre n_pre l ** &( "mid") # Int |->_)))))))))))

